# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

#  GROQ
GROQ_API_KEY=your_api_key_here

# LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="ai-career-assistant-v1"

# Project PostgreSQL
POSTGRES_DB=ai_career
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_project_postgres_password_here
POSTGRES_HOST=project-postgres
POSTGRES_PORT=5432

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Airflow runtime
AIRFLOW_UID=50000
EMAIL_YOUR=your_email@example.com
ADZUNA_APP_ID=id
ADZUNA_APP_KEY=key
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__API_AUTH__JWT_SECRET=your_airflow_jwt_secret_here
USAJOBS_API_KEY=your_usajobs_key_here


# Airflow web user
_AIRFLOW_WWW_USER_USERNAME=airflow_admin
_AIRFLOW_WWW_USER_PASSWORD=your_airflow_admin_password_here

# Airflow PostgreSQL
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=your_airflow_postgres_password_here
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_HOST=airflow-postgres
AIRFLOW_POSTGRES_PORT=5432

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_password

S3_ENDPOINT_URL="http://minio:9000"
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_this_password
S3_BUCKET=raw
S3_BUCKET_RESUMES=resumes
S3_BUCKET_REPORTS=reports